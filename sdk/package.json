{
  "name": "@hermes/agent-sdk",
  "version": "1.0.0",
  "description": "SDK for integrating AI Agents with Hermes Debugger",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./openai": {
      "import": {
        "types": "./dist/openai.d.mts",
        "default": "./dist/openai.mjs"
      },
      "require": {
        "types": "./dist/openai.d.ts",
        "default": "./dist/openai.js"
      }
    },
    "./anthropic": {
      "import": {
        "types": "./dist/anthropic.d.mts",
        "default": "./dist/anthropic.mjs"
      },
      "require": {
        "types": "./dist/anthropic.d.ts",
        "default": "./dist/anthropic.js"
      }
    },
    "./langchain": {
      "import": {
        "types": "./dist/langchain.d.mts",
        "default": "./dist/langchain.mjs"
      },
      "require": {
        "types": "./dist/langchain.d.ts",
        "default": "./dist/langchain.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/openai.ts src/anthropic.ts src/langchain.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --watch"
  },
  "keywords": [
    "ai",
    "agent",
    "debugger",
    "openai",
    "anthropic",
    "langchain",
    "observability"
  ],
  "author": "Hermes",
  "license": "MIT",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "langchain": ">=0.1.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "langchain": "^1.3.4",
    "openai": "^6.34.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  }
}
